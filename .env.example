# ==========================================
# LLM Configuration (LiteLLM model string)
#
# Local (Ollama):
#   LITELLM_MODEL=ollama/gemma3:12b
#   OLLAMA_API_BASE=http://localhost:11434
#
# Local (LM Studio):
#   LITELLM_MODEL=openai/local-model-name
#   LITELLM_API_BASE=http://localhost:1234/v1
#
# OpenAI:
#   LITELLM_MODEL=openai/gpt-4o
#   OPENAI_API_KEY=sk-...
#
# Anthropic:
#   LITELLM_MODEL=anthropic/claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Google Gemini:
#   LITELLM_MODEL=gemini/gemini-2.0-flash
#   GOOGLE_API_KEY=...
#
# OpenRouter:
#   LITELLM_MODEL=openrouter/google/gemma-3-12b
#   OPENROUTER_API_KEY=sk-or-...
# ==========================================
LITELLM_MODEL=openai/gpt-4o

# Custom base URL — set for LM Studio or any OpenAI-compatible endpoint.
# Leave empty for Ollama (uses OLLAMA_API_BASE) and cloud providers.
LITELLM_API_BASE=

# Provider API keys - set only the ones you use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Ollama base URL (only needed if not running on default port 11434)
OLLAMA_API_BASE=http://localhost:11434

# ==========================================
# ChromaDB Vector Store
# Embeddings are computed internally - no embedding model key needed.
# ==========================================
CHROMADB_PATH=data/chromadb

# ==========================================
# RAG Retrieval Tuning
# ==========================================
TOP_K_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==========================================
# Application
# ==========================================
APP_NAME=HR Assistant
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-in-production

# ==========================================
# Chainlit Auth (required when using @cl.header_auth_callback)
# Generate with: chainlit create-secret
# ==========================================
CHAINLIT_AUTH_SECRET=
